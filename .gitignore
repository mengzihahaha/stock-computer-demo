# ============================================================
# .gitignore
# ------------------------------------------------------------
# 作用：告诉 Git 哪些文件「不要」提交到仓库。
# 比如虚拟环境、缓存、密钥等，既没必要也不该上传。
# ============================================================

# Python 运行时产生的缓存
__pycache__/
*.py[cod]

# 虚拟环境目录（每个人本地自己建，不上传）
venv/
.venv/
env/

# 数据缓存 / 下载的数据文件
*.csv
*.pkl
data_cache/

# 编辑器 / 系统文件
.vscode/
.idea/
.DS_Store

# Streamlit 本地配置
.streamlit/secrets.toml
